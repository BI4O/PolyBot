# PolyBot 环境变量示例
# ============================================

# ============================================
# 场景 1：本地开发
# 使用方式：cp .env.example .env
# ============================================
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://ai.example.com

LANGGRAPH_PORT=2024

# ============================================
# 场景 2：Docker 部署
# 使用方式：cp .env.example .env.docker
# ============================================
# DEEPSEEK_API_KEY=sk-your-deepseek-api-key
#
# LANGGRAPH_HOST=0.0.0.0
# LANGGRAPH_PORT=8123
# NEWS_FETCH_INTERVAL=900
# NEWS_DB_PATH=/app/data/news.db
#
# HTTPS_PROXY=http://host.docker.internal:7897
# HTTP_PROXY=http://host.docker.internal:7897
# NO_PROXY=localhost,127.0.0.1,0.0.0.0,langgraph-api,news-fetcher
